[
  {
    "layer": "top",
    "position": "left",
    "modules-left": [
      "custom/os",
      "hyprland/workspaces"
    ],
    "modules-center": [
      "custom/cava"
    ],
    "modules-right": [
      "custom/spotify",
      "group/brightness",
      "group/sound",
      "group/power"
    ],
    "custom/os": {
      "format": "ÔåÉ‚Äâ",
      // Ó∏ï
      "on-click": "rofi -show drun -display-drun '>'",
      "tooltip": false
    },
    "hyprland/workspaces": {
      "format": "{}",
      "on-click": "activate"
    },
    "custom/cava": {
      "format": "{}",
      "rotate": 270,
      "exec": "/home/calciumking/.config/waybar/scripts/cava.sh",
      "tooltip": false,
      "on-click": "kitty --title float -e cava"
    },
    "custom/spotify": {
      "exec": "~/.config/waybar/scripts/spotify.sh",
      "format": "ÔÜº‚Äâ",
      "tooltip-format": "{}",
      "interval": 2,
      "return-type": "json",
      "on-click": "playerctl play-pause",
      "on-click-right": "hyprctl dispatch focuswindow class:Spotify",
      "on-scroll-up": "playerctl next",
      "on-scroll-down": "playerctl previous"
    },
    "group/brightness": {
      "orientation": "vertical",
      "drawer": {
        "transition-duration": 500,
        "transition-left-to-right": false
      },
      "modules": [
        "backlight",
        "backlight/slider"
      ]
    },
    "backlight": {
      "device": "intel_backlight",
      "format": "{icon}",
      "tooltip-format": "{percent}%",
      "format-icons": ["Óéç", "Óèì", "Óèë", "Óèè", "Óèé", "Óèç", "Óèä", "Óèà", "Óéõ"],
      "on-scroll-up": "exec brightnessctl set 1%+",
      "on-scroll-down": "exec brightnessctl set 1%-"
    },
    "backlight/slider": {
      "orientation": "vertical"
    },
    "group/sound": {
      "orientation": "vertical",
      "drawer": {
        "transition-duration": 500,
        "transition-left-to-right": false
      },
      "modules": [
        "pulseaudio",
        "pulseaudio#mic",
        "pulseaudio/slider"
      ]
    },
    "pulseaudio": {
      "format": "{icon}",
      "tooltip-format": "{volume}% - {desc}",
      "format-bluetooth": "{icon}",
      "format-muted": "Óª®‚Äâ",
      "format-icons": {
        "headphone": "ÔÄ•",
        "hands-free": "ÔÄ•",
        "headset": "ÔÄ•",
        "phone": "ÔÇï",
        "portable": "ÔÇï",
        "car": "ÔÜπ",
        "default": ["ÔÄ¶", "ÔÄß", "ÔÄ®‚Äâ‚Äâ"]
      },
      "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
      "on-click-right": "pavucontrol",
      "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_SINK@ 5%+",
      "on-scroll-down": "wpctl set-volume @DEFAULT_SINK@ 5%-",
      "smooth-scrolling-threshold": 1
    },
    "pulseaudio/slider": {
      "orientation": "vertical"
    },
    "pulseaudio#mic": {
      "format": "{format_source}",
      "format-source": "ÔÑ∞",
      "format-source-muted": "ÔÑ± ",
      "on-click": "wpctl set-mute @DEFAULT_SOURCE@ toggle"
    },
    "group/power": {
      "orientation": "vertical",
      "drawer": {
        "transition-duration": 500,
        "transition-left-to-right": false
      },
      "modules": [
        "custom/shutdown",
        "custom/hibernate",
        "custom/suspend",
        "custom/reboot"
      ]
    },
    "custom/shutdown": {
      "format": "‚èª‚Äâ",
      "tooltip-format": "Shutdown",
      "on-click": "systemctl poweroff"
    },
    "custom/reboot": {
      "format": "ÔÄû",
      "tooltip-format": "Reboot",
      "on-click": "systemctl reboot"
    },
    "custom/suspend": {
      "format": "ÔÅå",
      "tooltip-format": "Suspend",
      "on-click": "systemctl suspend"
    },
    "custom/hibernate": {
      "format": "ÔÇÝ‚Äâ",
      "tooltip-format": "Hibernate",
      "on-click": "systemctl hibernate"
    }
  },
  {
    "layer": "top",
    "position": "top",
    "modules-left": [
      "wlr/taskbar"
    ],
    "modules-center": [
      "clock"
    ],
    "modules-right": [
      "group/system",
      "group/connections",
      "battery"
    ],
    "wlr/taskbar": {
      "format": "{icon}",
      "icon-size": 18,
      "on-click": "activate"
    },
    "clock": {
      "format": " {:%I:%M %p} ",
      // vertical format: "{:%I\n%M\n%p\n‚Äî‚Äî\n%m\n%d}"
      "tooltip-format": "{:%A, %B %d, %Y}",
      "on-click": "kitty --title float -e tty-clock -sctb"
    },
    "group/system": {
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": 500,
        "transition-left-to-right": false
      },
      "modules": [
        "custom/system-icon",
        "cpu",
        "memory",
        "disk",
        "temperature"
      ]
    },
    "custom/system-icon": {
      "format": "‚ÄâÔÑâ ‚Äâ",
      "tooltip-format": "Open Btop",
      "on-click": "kitty -e btop"
    },
    "cpu": {
      "format": "Ôíº "
    },
    "memory": {
      "format": "ÓøÖ ",
      "tooltip-format": "{percentage}% - {used}GiB / {total}GiB"
    },
    "disk": {
      "interval": 30,
      "format": "ÔÇÝ ",
      "tooltip-format": "{percentage_used}% - {used} / {total}"
    },
    "temperature": {
      "format": "{icon}‚Äâ",
      "format-icons": ["Ôãú", "Ôãã", "Ôãä", "Ôãâ", "Ôãà", "Ôãá", "Û∞à∏"],
      "tooltip-format": "{temperatureF}¬∞F ({temperatureC}¬∞C)"
    },
    "group/connections": {
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": 500,
        "transition-left-to-right": false
      },
      "modules": [
        "network",
        "bluetooth"
      ]
    },
    "network": {
      "format-wifi": "‚Äâ{icon} ",
      "format-ethernet": "‚Äâ‚ÄâÓΩÑ ",
      "tooltip-format": "{essid} ({signalStrength}%) - {ifname} via {ipaddr}",
      "format-linked": "‚Äâ‚ÄâÔàõ ",
      "format-disabled": "‚ÄâÛ∞§Æ ",
      "format-disconnected": "‚ÄâÛ∞§´ ",
      "format-icons": ["Û∞§´", "Û∞§Ø", "Û∞§ü", "Û∞§¢", "Û∞§•", "Û∞§®"],
      "on-click": "zsh ~/.config/waybar/scripts/wifi-menu.sh"
    },
    "bluetooth": {
      "format": "Ôäî",
      "format-disabled": "Û∞Ç≤",
      "format-connected": "Óì¢ {num_connections}",
      "tooltip-format-disabled": "Off",
      "tooltip-format": "{controller_alias}\t{controller_address}",
      "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "on-click": "blueman-manager"
    },
    "battery": {
      "format": " {icon} ",
      "format-charging": " {icon} ",
      // laptop uses plug power instead of battery power
      "format-full": " Ôá¶ ",
      "tooltip-format": "{capacity}% - {time}",
      "format-time": "{H}h{M}m",
      "tooltip-format-full": "Full",
      "format-icons": {
        "default": ["Û±Éç", "Û∞Å∫", "Û∞Åª", "Û∞Åº", "Û∞ÅΩ", "Û∞Åæ", "Û∞Åø", "Û∞ÇÄ", "Û∞ÇÅ", "Û∞ÇÇ", "Û∞Åπ"],
        "charging": ["Û∞¢ü", "Û∞¢ú", "Û∞ÇÜ", "Û∞Çá", "Û∞Çà", "Û∞¢ù", "Û∞Çâ", "Û∞¢û", "Û∞Çä", "Û∞Çã", "Û∞ÇÖ"]
      },
      "interval": 5,
      "states": {
        "warning": 15,
        "critical": 10
      }
    }
  }
]
